sampleT <- function(n,lambda,alpha){
for(i in 1:n){
t <- rexp(10^6,lambda[i])
p <- trunc((1-alpha[i])*10^6)
t[1:p] <- rep(0,p)
sample <- sample + t
return(sample)}
}
