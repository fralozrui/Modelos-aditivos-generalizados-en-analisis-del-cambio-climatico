pSigma <- function(n,lambda,alpha,sigma){
sam <- sampleT(n,lambda,alpha)$sample
a <- sampleT(n,lambda,alpha)$c
s <- filt(sigma,a*sam)
prob <- sum(s)/10^6
return(prob)}
