sampleT <- function(n,lambda,alpha){
for(i in 1:n){
t <- rexp(10^6,lambda[i])
a <- runif(10^6,0,1)
sample <- sample + filt(a,alpha[i])*t
return(sample)}
sample <- rep(0,10^6)
c <- rep(1,10^6)
sampleT <- function(n,lambda,alpha){
for(i in 1:n){
t <- rexp(10^6,lambda[i])
a <- rbinom(10^6,1,alpha[i])
c <- a*c
if(i== 1){sample <- sample + t}
else{
sample <- sample + a*t}
lista <- list(sample = sample,c = c)
return(lista)}
}
